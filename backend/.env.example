# Ambiente: development | production | test
NODE_ENV=development

# Porta em que a API vai escutar
PORT=3000

# String de conexão do MySQL usada pelo Prisma
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="mysql://root:senha@localhost:3306/finance_ai"

# Segredo usado para assinar os tokens JWT.
# Gere um valor forte, por exemplo com: openssl rand -base64 48
JWT_SECRET="troque-por-um-segredo-aleatorio-de-no-minimo-32-caracteres"

# Tempo de expiração do token (formato aceito pela lib 'ms', ex: 7d, 12h, 30m)
JWT_EXPIRES_IN=7d

# Origens permitidas para CORS (separadas por vírgula se houver mais de uma)
CORS_ORIGIN=http://localhost:3001
